{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/ai-meta-kernel/task-object.schema.json",
  "title": "AI Meta Kernel Task Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "raw_request",
    "kernel_stage",
    "framed_objective",
    "task_classification",
    "risk_profile",
    "triggered_habits",
    "structural_decomposition",
    "required_checks",
    "status_flags",
    "verification_plan",
    "challenge_loop",
    "downstream_recommendation",
    "handoff"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable task identifier generated by the kernel or orchestrator."
    },
    "raw_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "received_at"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_context": {
          "type": "string",
          "description": "Optional conversation, workspace, or channel context."
        }
      }
    },
    "kernel_stage": {
      "type": "string",
      "enum": [
        "intake",
        "framing",
        "normalize",
        "frame",
        "classify",
        "trigger",
        "decompose",
        "calibrate",
        "risk_calibration",
        "habit_triggering",
        "verification_planning",
        "challenge_loop",
        "gate",
        "emit",
        "handoff_ready",
        "downstream_running",
        "returned_for_review"
      ]
    },
    "framed_objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_request",
        "core_goal",
        "success_criteria",
        "scope",
        "non_goals",
        "reframe_required"
      ],
      "properties": {
        "surface_request": { "type": "string", "minLength": 1 },
        "core_goal": { "type": "string", "minLength": 1 },
        "success_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "non_goals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "time_horizon": {
          "type": ["string", "null"]
        },
        "reframe_required": { "type": "boolean" },
        "reframe_note": { "type": "string" }
      }
    },
    "task_classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_type", "secondary_types"],
      "properties": {
        "primary_type": {
          "type": "string",
          "enum": [
            "information",
            "analysis",
            "decision",
            "creation",
            "planning",
            "debugging",
            "negotiation",
            "ethical"
          ]
        },
        "secondary_types": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "information",
              "analysis",
              "decision",
              "creation",
              "planning",
              "debugging",
              "negotiation",
              "ethical"
            ]
          }
        }
      }
    },
    "risk_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_level",
        "categories",
        "rationale",
        "escalation_required",
        "ambiguity_level",
        "alignment_needed",
        "confidence_ceiling"
      ],
      "properties": {
        "overall_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "ambiguity_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "categories": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "financial",
              "legal",
              "medical",
              "safety",
              "security",
              "privacy",
              "reputational",
              "ethical",
              "time_sensitive",
              "externality",
              "none_identified"
            ]
          },
          "minItems": 1,
          "not": {
            "allOf": [
              { "contains": { "const": "none_identified" } },
              { "minItems": 2 }
            ]
          }
        },
        "rationale": { "type": "string", "minLength": 1 },
        "escalation_required": { "type": "boolean" },
        "alignment_needed": { "type": "boolean" },
        "confidence_ceiling": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "triggered_habits": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "contains": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": { "const": "primary" }
        }
      },
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["habit_id", "role", "reason", "required"],
        "properties": {
          "habit_id": {
            "type": "string",
            "enum": ["H1", "H2", "H3", "H4", "H5", "H6", "H7", "H8", "H9", "H10", "H11"]
          },
          "role": {
            "type": "string",
            "enum": ["primary", "support"]
          },
          "reason": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        }
      }
    },
    "structural_decomposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facts",
        "assumptions",
        "inferences",
        "unknowns",
        "constraints",
        "stakeholders",
        "tradeoffs"
      ],
      "properties": {
        "facts": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "inferences": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "unknowns": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hard", "soft"],
          "properties": {
            "hard": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "soft": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
          }
        },
        "stakeholders": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "tradeoffs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "required_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_verify",
        "must_challenge",
        "must_disclose_uncertainty",
        "must_align_with_user"
      ],
      "properties": {
        "must_verify": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "must_challenge": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "wrong_question_check",
              "missing_constraint_check",
              "alternative_explanation_check",
              "counterargument_check",
              "overconfidence_check",
              "stakeholder_check",
              "ethics_externality_check",
              "simplicity_robustness_check",
              "reversibility_check",
              "handoff_clarity_check"
            ]
          }
        },
        "must_disclose_uncertainty": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "must_align_with_user": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "status_flags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "not": {
        "anyOf": [
          {
            "allOf": [
              { "contains": { "const": "ready_for_handoff" } },
              { "contains": { "const": "needs_reframe" } }
            ]
          },
          {
            "allOf": [
              { "contains": { "const": "ready_for_handoff" } },
              { "contains": { "const": "needs_user_clarification" } }
            ]
          }
        ]
      },
      "items": {
        "type": "string",
        "enum": [
          "ready_for_handoff",
          "needs_reframe",
          "needs_verification",
          "needs_user_alignment",
          "needs_user_clarification",
          "high_risk_restricted",
          "ethics_escalated"
        ]
      }
    },
    "verification_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "methods", "freshness_requirement", "citation_requirement"],
      "properties": {
        "required": { "type": "boolean" },
        "methods": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "source_check",
              "cross_source_corroboration",
              "schema_validation",
              "calculation_check",
              "expert_review",
              "user_confirmation",
              "citation_audit",
              "none"
            ]
          }
        },
        "freshness_requirement": {
          "type": "string",
          "enum": ["none", "recent", "current", "real_time"]
        },
        "citation_requirement": {
          "type": "string",
          "enum": ["none", "recommended", "required"]
        },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "required": { "const": true }
            }
          },
          "then": {
            "properties": {
              "methods": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "challenge_loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["performed", "challenges", "result"],
      "properties": {
        "performed": { "type": "boolean" },
        "challenges": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "question", "resolution"],
            "properties": {
              "target": {
                "type": "string",
                "enum": ["user_framing", "kernel_assumption", "downstream_path", "evidence", "ethics"]
              },
              "question": { "type": "string", "minLength": 1 },
              "resolution": { "type": "string", "minLength": 1 }
            }
          }
        },
        "result": {
          "type": "string",
          "enum": [
            "proceed",
            "proceed_with_constraints",
            "clarify_first",
            "reframe_first",
            "escalate",
            "decline"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "performed": { "const": true }
            }
          },
          "then": {
            "properties": {
              "challenges": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "downstream_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_type", "mode", "output_format", "rationale"],
      "properties": {
        "agent_type": { "type": "string", "minLength": 1 },
        "mode": {
          "type": "string",
          "enum": ["do_not_handoff", "restricted_handoff", "standard_handoff"]
        },
        "output_format": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "restrictions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["downstream_agent", "handoff_ready", "instructions", "expected_outputs"],
      "properties": {
        "downstream_agent": { "type": "string", "minLength": 1 },
        "handoff_ready": { "type": "boolean" },
        "instructions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "expected_outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}

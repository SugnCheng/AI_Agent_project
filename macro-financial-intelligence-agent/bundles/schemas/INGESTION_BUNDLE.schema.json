{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/INGESTION_BUNDLE.schema.json",
  "title": "INGESTION_BUNDLE",
  "description": "Canonical ingestion bundle schema for macro-financial-intelligence-agent v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_metadata",
    "bundle_context",
    "items"
  ],
  "properties": {
    "bundle_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "run_mode",
        "generated_at",
        "date_range",
        "regions",
        "source_count",
        "item_count_raw",
        "item_count_after_dedup"
      ],
      "properties": {
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "run_mode": {
          "type": "string",
          "enum": [
            "daily_brief_run",
            "weekly_intelligence_run",
            "custom_range_run",
            "event_watch_run"
          ]
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "date_range": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string",
              "format": "date-time"
            },
            "end": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "item_count_raw": {
          "type": "integer",
          "minimum": 0
        },
        "item_count_after_dedup": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "bundle_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_target",
        "watchlist_topics",
        "operator_notes"
      ],
      "properties": {
        "report_target": {
          "type": "string",
          "enum": [
            "daily_brief",
            "weekly_intelligence_report",
            "special_event_memo"
          ]
        },
        "watchlist_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operator_notes": {
          "type": "string"
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "source_id",
          "authority_tier",
          "region",
          "published_at",
          "title",
          "canonical_url",
          "content_type",
          "topic_tags",
          "market_tags",
          "risk_tags",
          "preliminary_priority",
          "summary_seed",
          "raw_excerpt",
          "dedup_group_id"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "authority_tier": {
            "type": "string",
            "enum": [
              "TIER_1",
              "TIER_2",
              "TIER_3",
              "TIER_4"
            ]
          },
          "region": {
            "type": "string",
            "minLength": 1
          },
          "published_at": {
            "type": "string",
            "format": "date-time"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "canonical_url": {
            "type": "string",
            "format": "uri"
          },
          "content_type": {
            "type": "string",
            "minLength": 1
          },
          "topic_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "market_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preliminary_priority": {
            "type": "string",
            "enum": [
              "P1",
              "P2",
              "P3",
              "DROP"
            ]
          },
          "summary_seed": {
            "type": "string"
          },
          "raw_excerpt": {
            "type": "string"
          },
          "dedup_group_id": {
            "type": "string",
            "minLength": 1
          },
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "language": {
            "type": "string"
          },
          "official_status": {
            "type": "string"
          },
          "priority_weight": {
            "type": "number",
            "minimum": 0
          },
          "trust_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "event_cluster_id": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}